{
  "schemaVersion": 1,
  "id": "speedboot",
  "version": "${version}",
  "name": "SpeedBoot",
  "description": "Speeds up Minecraft startup by skipping unnecessary processes. Optimized for low-RAM devices like TV Box.",
  "authors": [
    "SpeedBoot Contributors"
  ],
  "contact": {},
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.speedboot.SpeedBootMod"
    ],
    "client": [
      "com.speedboot.SpeedBootClientMod"
    ]
  },
  "mixins": [
    "speedboot.mixins.json",
    "speedboot.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.20.5",
    "java": ">=21"
  }
}
